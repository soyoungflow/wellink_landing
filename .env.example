# ===========================================
# Vercel Serverless Function (api/airtable.js)
# Vercel 대시보드 → 프로젝트 → Settings → Environment Variables 에서 설정
# ===========================================

# 필수
AIRTABLE_PAT=your_personal_access_token
AIRTABLE_BASE_ID=your_base_id

# 테이블 ID (필수)
AIRTABLE_TABLE_EMPLOYEE=your_employee_table_id
AIRTABLE_TABLE_MANAGER=your_manager_table_id
AIRTABLE_TABLE_WCWI=your_wcwi_table_id
AIRTABLE_TABLE_MINI=your_mini_table_id

# Select 옵션 권한 에러 방지 (선택)
# ERROR: choices에 없는 값 → 검증 에러 (기본)
# SYNONYM_MAP: 사전 매핑 테이블로 치환
# OTHER_FALLBACK: "기타"/"Other" 옵션으로 치환 (해당 옵션이 있을 때만)
# AIRTABLE_SELECT_INVALID_HANDLING=ERROR

# ===========================================
# 로컬 개발 시 프론트엔드 (선택)
# Vite가 사용. 로컬에서 별도 API 서버를 띄울 때만 필요
# ===========================================
# VITE_API_BASE_URL=http://localhost:3000
